{
  "name": "regulatory-ground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @regground/api dev\" \"pnpm --filter @regground/web dev\"",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "test:harness": "pnpm --filter @regground/sandbox test:harness",
    "db:push": "pnpm --filter @regground/core db:push",
    "seed:graph": "pnpm --filter @regground/core seed:graph",
    "seed:all": "pnpm seed:graph",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "eval": "pnpm --filter @regground/evals eval",
    "eval:all": "pnpm --filter @regground/evals eval:all",
    "check:graph": "node scripts/check-graph-quality.mjs"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.21.0"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "yaml": "^2.4.0"
  }
}
