# Regulatory Ground environment template.
# Copy to .env for local development. Never commit real secrets.

# Runtime
NODE_ENV=development
PORT=4000
API_PORT=4000
API_HOST=0.0.0.0

# API auth
JWT_SECRET=change-me-in-local-dev-only
JWT_SECRET_PREVIOUS=
AUTH_BYPASS_DEV=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
PLATFORM_ADMIN_USER_IDS=

# Clerk auth
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk dashboard webhook endpoint:
#   https://<api-domain>/api/clerk-webhook
# Subscribe to: user.created, user.updated, organization.created,
# organization.updated, organization.deleted, organizationMembership.created,
# organizationMembership.updated, organizationMembership.deleted.
CLERK_WEBHOOK_SIGNING_SECRET=

# Databases
DATABASE_URL=postgres://postgres:postgres@localhost:5432/regground
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Web
VITE_API_URL=http://localhost:4000
VITE_SESSION_IDLE_TIMEOUT_MINUTES=15
VITE_SESSION_AWAY_TIMEOUT_MINUTES=10
VITE_SESSION_WARNING_SECONDS=60

# Signed-in live PSUR service. Signed-out /demo/psur simulation does not require this.
PSUR_SERVICE_URL=http://localhost:8000

# LLM providers. Configure at least one for live agent/PSUR generation.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# MCP server
MCP_TRANSPORT=stdio
MCP_PORT=3100
