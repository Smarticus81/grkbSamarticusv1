# === PostgreSQL (operational store) ===
DATABASE_URL=postgresql://regground:regground@localhost:5432/regground

# === Neo4j (obligation graph - source of truth) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=regground
NEO4J_DATABASE=neo4j

# === API ===
API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET=change-me-in-production
# Previous JWT secret for graceful key rotation (optional)
JWT_SECRET_PREVIOUS=

# === Auth (Clerk) ===
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# === CORS / Security ===
# Comma-separated list of allowed origins (e.g. https://app.regground.com,https://staging.regground.com)
ALLOWED_ORIGINS=
# Set to "true" to bypass auth in development (never enable in production)
AUTH_BYPASS_DEV=false

# === Web ===
VITE_API_URL=http://localhost:4000

# === LLM Providers (capability-based; configure any/all) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Enable cross-provider LLM result verification (true/false)
ENABLE_LLM_CROSS_CHECK=false

# === MCP Server ===
# Transport mode: "stdio" (default for IDE integration) or "http" (for cloud/API)
MCP_TRANSPORT=
# HTTP port for MCP server when using http transport (default: 3100)
MCP_PORT=
# Max response size in bytes for MCP tool responses
MCP_MAX_RESPONSE_BYTES=

# === Caching ===
# Redis connection URL for caching layer (optional)
REDIS_URL=

# === Observability ===
# OpenTelemetry collector endpoint (e.g. http://localhost:4318)
OTEL_EXPORTER_OTLP_ENDPOINT=

# === Runtime ===
NODE_ENV=development
LOG_LEVEL=info
