{
  "name": "@regground/sandbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/sandbox/src/index.js",
  "types": "./dist/sandbox/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sandbox/src/index.d.ts",
      "default": "./dist/sandbox/src/index.js"
    },
    "./*": {
      "types": "./dist/sandbox/src/*.d.ts",
      "default": "./dist/sandbox/src/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:harness": "vitest run --dir src/processes"
  },
  "dependencies": {
    "@regground/core": "workspace:*",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
