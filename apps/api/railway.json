{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.api",
    "watchPatterns": [
      "apps/api/**",
      "packages/core/**",
      "packages/sandbox/**",
      "Dockerfile.api",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "node apps/api/dist/apps/api/src/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
